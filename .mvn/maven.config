-Dgib.buildDownstream=always
-Dgib.buildUpstream=always
-Dgib.skipTestsForUpstreamModules=true
-Dgib.buildAllIfNoChanges=false
-Dgib.skipTestsForUpstreamModules=true
-Dgib.untracked=false
-Dgib.excludePathsMatching=.*\.md|Jenkinsfile|\.gitignore
-Dgib.buildUpstreamMode=impacted
-Dgib.failOnError=true
-DsendCredentialsOverHttp=true
